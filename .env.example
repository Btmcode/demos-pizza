# ============================================================
#  Demos Pizza · Environment Variables
#  Local development için .env (production'da Vercel env vars kullanılır)
#
#  ⚠️ BU DOSYAYI KOPYALAYIN: cp .env.example .env
#  ⚠️ .env dosyanızı ASLA commit'lemeyin (zaten .gitignore'da)
#  ⚠️ Tüm <...> placeholder'ları gerçek değerlerle değiştirin
# ============================================================

# --- Database ---
# Local dev: SQLite (varsayılan)
# Production (Vercel + Neon): postgresql connection string
#   Örnek: postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL="file:./db/custom.db"

# --- NextAuth ---
# Üretim ortamı için rastgele uzun bir string olmalı: `openssl rand -base64 48`
NEXTAUTH_SECRET="<ÜRETİM_İÇİN_RASTGELE_32_BAYT_STRING>"
NEXTAUTH_URL="http://localhost:3000"

# --- Public Site URL (OpenGraph, canonical) ---
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# --- Allowed Origins for CORS (comma-separated) ---
NEXT_PUBLIC_ALLOWED_ORIGINS="https://your-domain.vercel.app,http://localhost:3000"

# --- Admin bootstrap (seed script okur, sonra kaldırın) ---
# İlk admin kullanıcı bilgileri — seed çalıştırınca oluşturulur
# ⚠️ GÜÇLÜ ŞİFRE KULLANIN: min 12 karakter, büyük/küçük harf, rakam, sembol
# ⚠️ Seed'den sonra bu değişkeni .env'den KALDIRIN
ADMIN_BOOTSTRAP_EMAIL="admin@yourdomain.com"
ADMIN_BOOTSTRAP_PASSWORD="<GÜÇLÜ_ŞİFRE_BURAYA>"

# --- Optional: Stripe (online ödeme için ileride) ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
